# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/socialhub

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# App login OAuth (Google + GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Social platform OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# AI
ANTHROPIC_API_KEY=

# Mailer (Resend — https://resend.com)
# Leave blank in dev to log outgoing mail to the console instead of sending.
RESEND_API_KEY=
RESEND_FROM=SocialHub <onboarding@resend.dev>

# Captcha (Cloudflare Turnstile) — optional; both required to enable
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Encryption (32-byte hex string for AES-256 token encryption)
ENCRYPTION_KEY=

# Storage
STORAGE_PROVIDER=local   # or 's3'
STORAGE_LOCAL_PATH=./storage
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Prod-only: set on the web container to stop it from running the inline
# BullMQ worker. Run `pnpm worker` in a separate process/container instead.
DISABLE_INLINE_WORKER=
