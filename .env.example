# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/socialhub

# Redis
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Social platform OAuth
# Google + GitHub are for connecting accounts only (not app login).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# AI
ANTHROPIC_API_KEY=

# Observability (optional)
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
LOG_LEVEL=info

# Link shortener — 'local' uses our in-app /l/<slug> redirect.
# 'dub' mints dub.sh (or custom-domain) links via the Dub API and wires
# in @dub/better-auth for user-to-link attribution.
SHORTENER_PROVIDER=local
DUB_API_KEY=
DUB_DOMAIN=           # optional — custom short domain, else dub.sh
DUB_WORKSPACE_ID=     # optional — scope links to a specific Dub workspace

# Billing — pick one of: stripe, polar, dodo, autumn, creem, chargebee, none
BILLING_PROVIDER=none

# Stripe (BILLING_PROVIDER=stripe) — Better Auth plugin provided
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-plan price ids (one env var per plan name)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Polar (BILLING_PROVIDER=polar) — Better Auth plugin provided
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_BUSINESS=

# Dodo Payments (BILLING_PROVIDER=dodo) — Better Auth plugin provided
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_STARTER=
DODO_PRODUCT_PRO=
DODO_PRODUCT_BUSINESS=

# Autumn Billing (BILLING_PROVIDER=autumn)
AUTUMN_SECRET_KEY=
AUTUMN_WEBHOOK_SECRET=
AUTUMN_PRODUCT_STARTER=
AUTUMN_PRODUCT_PRO=
AUTUMN_PRODUCT_BUSINESS=

# Creem (BILLING_PROVIDER=creem)
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_PRODUCT_STARTER=
CREEM_PRODUCT_PRO=
CREEM_PRODUCT_BUSINESS=

# Chargebee (BILLING_PROVIDER=chargebee) — webhooks use HTTP basic auth
CHARGEBEE_SITE=
CHARGEBEE_API_KEY=
CHARGEBEE_WEBHOOK_USER=
CHARGEBEE_WEBHOOK_PASSWORD=
CHARGEBEE_PLAN_STARTER=
CHARGEBEE_PLAN_PRO=
CHARGEBEE_PLAN_BUSINESS=

# Mailer (Resend — https://resend.com)
# Leave blank in dev to log outgoing mail to the console instead of sending.
RESEND_API_KEY=
RESEND_FROM=SocialHub <onboarding@resend.dev>

# Captcha (Cloudflare Turnstile) — optional; both required to enable
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Encryption (32-byte hex string for AES-256 token encryption)
ENCRYPTION_KEY=

# Object storage (required — S3 or S3-compatible such as Cloudflare R2).
# For R2: set S3_ENDPOINT to https://<account>.r2.cloudflarestorage.com
# and STORAGE_PUBLIC_BASE_URL to your public R2 URL or custom CDN domain.
AWS_BUCKET=
AWS_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Prod-only: set on the web container to stop it from running the inline
# BullMQ worker. Run `pnpm worker` in a separate process/container instead.
DISABLE_INLINE_WORKER=
